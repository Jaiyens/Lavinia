# Copy to .env.local and fill in. .env.local is gitignored; never commit real keys.

# Database (Neon Postgres). Use your OWN per-dev Neon branch, never prod.
# DATABASE_URL = pooled endpoint (runtime); DATABASE_URL_UNPOOLED = direct endpoint
# (migrations / db push — pgbouncer can't run the DDL + advisory locks they need).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# --- Auth.js v5 (sign-in) ------------------------------------------------------
# Sign-in is Google SSO + email magic link (no passwords), Auth.js v5 + the Prisma
# adapter. All three values are env-only and must never be committed.

# Signs/encrypts the session cookie. REQUIRED in production (next start throws
# without it). Generate one with `npx auth secret` or `openssl rand -base64 33`.
AUTH_SECRET=""

# Public app origin. REQUIRED in production. The dashboard is deployed on its own
# subdomain, so set this to https://app.tryterra.ai. Auth.js uses it to build the OAuth
# callback + sign-in URLs (Google redirect URI: https://app.tryterra.ai/api/auth/callback/google).
# Local dev: http://localhost:3001
AUTH_URL="http://localhost:3001"

# Google OAuth credentials (https://console.cloud.google.com -> OAuth client).
# The Google sign-in button only appears when BOTH are set, so the build and the
# e2e run fine without them (the magic-link path still works).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Magic-link sender. The delivery boundary is STUBBED in v1 (the link is logged to
# the server console; copy it from there to sign in locally). A real sender
# (Resend/SMTP) is wired in prod; this address is the from-line it will use.
AUTH_EMAIL_FROM="login@terra.example"

# Pre-launch sign-in gate (the access allowlist). A comma-separated list of emails allowed to
# sign in (case-insensitive). In PRODUCTION this MUST be set: when it is unset or empty, prod
# fails closed and denies every sign-in (so the public domain is never wide open). In dev/test
# it can stay unset and sign-in is open, so local dev and CI are not locked out. Invited
# teammates can sign in during lockdown via their farm membership even if not listed here.
ACCESS_ALLOWLIST=""

# --- AI (Almond assistant + bill extraction) -----------------------------------
# Vercel AI Gateway key. Powers the LIVE Almond chat + live bill extraction; without it the
# app falls back to stubs (zero external calls), so build/tests/offline dev keep working.
# Auto-injected via OIDC on Vercel; set manually elsewhere. The code accepts
# AI_GATEWAY_API_KEY OR the legacy VERCEL_AI_SDK_API_KEY - set only one.
AI_GATEWAY_API_KEY=""

# --- UtilityAPI (live PG&E connect, the default provider) ----------------------
# The utility-data aggregator Terra uses to pull a grower's PG&E account. Unlike Bayou,
# one authorization form returns MANY authorizations (one per PG&E account), so a
# multi-account operation connects in a single pass. Without a token, the connect flow
# falls back to the committed multi-account sample (fixtures/utilityapi/), zero external
# calls, so tests and offline dev keep working.

# Server-only API token (Bearer auth). Never expose to the client and never commit it.
# Get it from the UtilityAPI dashboard (https://utilityapi.com -> account -> API).
UTILITYAPI_TOKEN=""

# Optional API base override. Defaults to https://utilityapi.com/api/v2; set only to
# point at a sandbox/proxy.
# UTILITYAPI_BASE="https://utilityapi.com/api/v2"

# Which live-connect provider to use: "utilityapi" (default) or "bayou" (the legacy
# fallback below, kept for one release). Leave unset for UtilityAPI.
# PGE_PROVIDER="utilityapi"

# --- Bayou (legacy live PG&E connect, behind PGE_PROVIDER=bayou) ----------------
# The previous provider, kept as a fallback until UtilityAPI is validated on a real
# multi-account authorization, then deleted. Only used when PGE_PROVIDER=bayou. Without
# these (or on the default UtilityAPI path), the connect flow falls back to the committed
# sample fixtures (zero external calls), so tests and offline dev keep working.

# staging.bayou.energy for the dev sandbox (Speculoos), bayou.energy for production.
# IMPORTANT: the key and the domain must be the SAME environment. A test key
# (test_... prefix) only works against staging.bayou.energy; a live key only against
# bayou.energy. Mixing them returns 401 "This key was not generated on the live
# environment." Use staging + a test key for the Speculoos quickstart, then switch
# both to live for real PG&E. Switching the domain (+ key) is the ONLY change needed
# to flip from the Speculoos sandbox to real PG&E: UTILITY defaults off this (below).
BAYOU_DOMAIN="staging.bayou.energy"

# Server-only secret (HTTP basic auth username, blank password). Never expose to the
# client and never commit it. Must match BAYOU_DOMAIN's environment (see above).
BAYOU_API_KEY=""

# The connect UI is now a hosted redirect (no JS embed), so the old
# NEXT_PUBLIC_BAYOU_COMPANY_ID is no longer used: PGE_PROVIDER=bayou opens Bayou's
# hosted onboarding page in a new tab.

# Which Bayou utility to create customers under. Leave UNSET to let it follow
# BAYOU_DOMAIN: staging -> speculoos_power (Bayou's fake utility, used with the test
# logins in the README), live -> pacific_gas_and_electric (real PG&E). Set it only to
# force a specific slug (e.g. if Bayou's code differs; confirm with listBayouUtilities()).
# UTILITY="speculoos_power"
