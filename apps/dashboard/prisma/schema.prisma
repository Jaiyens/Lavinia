// Terra shared data model, first-class entities reused by every tool.
// SQLite has no native enums, so union fields are String with the allowed
// values documented inline and mirrored as TS types in
// src/lib/recommendations/types.ts. Promote these to real enums on Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime uses the pooled Neon endpoint; migrations / db push use the direct (unpooled)
  // endpoint via directUrl (pgbouncer cannot run the DDL + advisory locks migrations need).
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Farm {
  id        String   @id @default(cuid())
  name      String
  timezone  String   @default("America/Los_Angeles")
  // Seed/fixture demo farms (e.g. Batth) are marked so they never present as the
  // grower's live farm on the dashboard. A real connected farm has isDemo = false.
  isDemo    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The signed-in grower who owns this farm (Auth.js User). Nullable: demo/seed
  // farms and any pre-auth farm own no user. Story 5.1 adds the column; Story 5.2
  // attaches connected farms to the user and filters the dashboard by ownership.
  // dashboardFarm()/currentFarm() do NOT yet filter on userId (see farm.ts).
  userId String?

  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  blocks          Block[]
  ranches         Ranch[]
  pumps           Pump[]
  entities        Entity[]
  accounts        Account[]
  solarArrays     SolarArray[]
  people          Person[]
  connections     Connection[]
  recommendations Recommendation[]
  generatedReports GeneratedReport[]
  agentRuns       AgentRun[]
  agentActions    AgentAction[]

  @@index([userId])
}

// A legal billing entity. Batth runs ~6 of these; each owns several PG&E accounts.
// The top of the Entity -> Account -> Meter hierarchy that makes 57 accounts across
// 6 entities navigable. Entity assignment for an account is filled in from the
// grower's master spreadsheet (the Bayou/ESPI feeds don't name the legal entity).
model Entity {
  id          String   @id @default(cuid())
  name        String
  // The legal entity carries two names the master spreadsheet separates: billingName
  // is how PG&E prints it (7 typo'd variants dedupe to 6 entities) and actualOwner is
  // the true legal owner. Both nullable here; Story 1.2 populates them from the
  // spreadsheet (the 7 billing-name variants -> billingName, 6 owners -> actualOwner).
  billingName String?
  actualOwner String?
  farmId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  farm     Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  accounts Account[]

  @@index([farmId])
}

// A PG&E account (the billing unit; ~57 for Batth). Carries the account number and
// links up to an Entity (nullable until the spreadsheet assigns it) and down to the
// meters that bill under it. accountNumber is a real link here, not a loose string.
model Account {
  id        String   @id @default(cuid())
  number    String // PG&E account number
  farmId    String
  entityId  String? // assigned once known (spreadsheet reconciliation)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Account-level billing coverage (FR-6): no_bill | needs_review | reconciled. Account-
  // level reconcile sets it in Story 1.7. Mirrored as CoverageState in TS.
  coverageState String @default("no_bill")

  farm   Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  entity Entity? @relation(fields: [entityId], references: [id], onDelete: SetNull)
  pumps  Pump[]

  @@unique([farmId, number]) // account numbers are unique; scope by farm to be safe
  @@index([farmId])
  @@index([entityId])
}

model Block {
  id        String   @id @default(cuid())
  name      String
  acreage   Float?
  farmId    String
  cropId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farm  Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  crop  Crop?  @relation(fields: [cropId], references: [id])
  pumps Pump[] // m-n: pumps that serve this block

  @@index([farmId])
}

model Pump {
  id                  String   @id @default(cuid())
  name                String
  serviceId           String? // PG&E service ID / ESPI UsagePoint
  meterSerial         String?
  rateSchedule        String? // e.g. "AG-C". Stored as read from the spreadsheet, never inferred.
  // deprecated: collapsing into serialCode in Story 1.2 (the new spreadsheet importer
  // and greenbutton/schedule.ts move to serialCode, then this column is dropped).
  billingSerial       String? // serial code that drives the meter-read / cycle close
  // The canonical billing-cycle letter going forward (supersedes billingSerial). Kept
  // strictly distinct from rotatingOutageBlock: only the serial letter drives cycle close.
  serialCode          String?
  rotatingOutageBlock String? // PG&E rotating-outage block; never used for cycle close
  location            String? // rough address from ESPI ServiceLocation
  horsepower          Float?
  // Meter commodity, distinct from powerSource (the pump motor's prime mover). The
  // engine is electric-only in v1; gas meters are carried through the normalizer but
  // not persisted as Pumps, so this stays "electric" here. Having the column makes
  // turning gas on later a flag flip, not a migration.
  fuel                String   @default("electric") // "electric" | "gas"
  // The PG&E account this meter bills under. Nullable: the ESPI feed carries no
  // account number, so ESPI-imported pumps link up only once the spreadsheet does.
  accountId           String?
  // Set at onboarding. kind is auto-classified from the usage signature (a big
  // seasonal load is a pump; a small flat one is an office/shop) and the farmer
  // can override it; non-pump meters are excluded from pump-timing advice.
  kind                String   @default("pump") // "pump" | "non_pump"
  powerSource         String   @default("electric") // "electric" | "diesel" | "gas"
  // Map pin. Pre-placed from `location` at onboarding, dragged to the real spot.
  latitude            Float?
  longitude           Float?
  // Pump capacity in gallons per minute, where the grower's records carry it.
  gpm                 Float?
  // Net-metering attributes for a solar-paired meter. nemType is the program
  // (e.g. "nem2"); trueUpMonth (1-12) is when credits/charges settle annually;
  // solarKw is the paired array's nameplate. All null on a meter with no solar.
  // (SolarArray models the NEMA allocation graph; isSolar is the day-one flag.)
  nemType             String?
  trueUpMonth         Int?
  solarKw             Float?
  // The printed annual true-up settlement (Story 3.4): amount in integer cents
  // (negative = net credit to the grower) and the statement date, as the NEM
  // reconciliation page prints them. Null until a true-up statement is extracted.
  trueUpAmountCents   Int?
  trueUpDate          DateTime?
  // The grower's own "P0xx" Pump ID descriptor from the master spreadsheet, distinct
  // from serviceId (SA ID) and the cuid primary key. Story 1.6 identity-checks on it.
  growerPumpId        String?
  // Legacy AG-4/AG-5 schedule flag. The 27 legacy-flagged meters lead rate optimization.
  isLegacy            Boolean  @default(false)
  // Pump health from the master spreadsheet's Status field (FR-17). Mirrored as PumpStatus.
  status              String? // "GOOD" | "BAD" | "NEW WELL" | "OLD"
  // Explicit solar flag (FR-1 "each Meter carries a Solar flag"), legible day one even
  // before the SolarArray/NEMA graph is wired from billing.
  isSolar             Boolean  @default(false)
  cropId              String? // crop carried on the meter (FR-1), alongside ranch/block crop
  ranchId             String? // rollup membership (Entity -> Account -> Ranch -> Meter)
  // Billing coverage for this meter (FR-6): no_bill | needs_review | reconciled. Defaults
  // to no_bill; Story 1.7 sets it from reconciliation. Mirrored as CoverageState in TS.
  coverageState       String   @default("no_bill")
  farmId              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  farm             Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  account          Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  crop             Crop?           @relation(fields: [cropId], references: [id])
  ranch            Ranch?          @relation(fields: [ranchId], references: [id], onDelete: SetNull)
  blocks           Block[] // m-n: block(s) this pump serves
  benefitingArrays SolarArray[]    @relation("NemAllocation") // NEMA: arrays whose credits offset this meter
  intervals        UsageInterval[] // 15-minute metered usage (Green Button)
  billingPeriods   BillingPeriod[] // per-cycle summary (tariff, demand charge, peak)
  nemPeriods       NemPeriod[] // printed NEM reconciliation months (Story 3.4)

  // A PG&E service ID is unique within a farm. SQLite treats NULL serviceIds as
  // distinct, so pumps without one are unaffected; lets the importer upsert by it.
  @@unique([farmId, serviceId])
  @@index([farmId])
  @@index([accountId])
}

// 15-minute interval usage for a Pump, parsed from Green Button / ESPI data.
// kWh stays unit-true to the meter; kW (demand) is derived in src/lib/energy.
// Shared primitive: any later tool that reads a metered load reuses this series.
model UsageInterval {
  id          String   @id @default(cuid())
  pumpId      String
  start       DateTime // interval start, UTC
  durationSec Int      @default(900) // PG&E intervals are 900s (15 min)
  kWh         Float
  createdAt   DateTime @default(now())

  pump Pump @relation(fields: [pumpId], references: [id], onDelete: Cascade)

  @@unique([pumpId, start]) // one reading per interval; makes re-import idempotent
  @@index([pumpId, start])
}

// One billing cycle's summary for a Pump (an ESPI UsageSummary). Dollar figures
// are read from the bill/ESPI data, never hardcoded. peakKw is the derived
// highest 15-minute demand in the window and is what sets the demand charge.
model BillingPeriod {
  id              String    @id @default(cuid())
  pumpId          String
  start           DateTime
  close           DateTime
  // The actual posted billing-cycle close from the scanned bill (AR-14): distinct from
  // `close` (the source period end) and from the scheduled serial-code close. Null until
  // a bill is extracted.
  cycleClose        DateTime?
  // The SA's printed total in integer cents (AR-6). Story 1.7 reconciles the sum of this
  // period's BillingLineItem.amountCents against it within one cent. Null until extracted.
  printedTotalCents Int?
  tariff          String? // rate schedule, e.g. "AG-C"
  demandChargeUsd Float? // total of the cycle's demand line items
  peakKw          Float? // derived max demand (highest 15-min kW)
  peakAt          DateTime? // when that peak occurred
  totalBillUsd    Float? // billLastPeriod
  // Total metered energy for the cycle (kWh). The summary feed carries this even for
  // meters with no 15-minute interval history, so fleet-wide usage is readable without
  // re-deriving from intervals. Null when the source did not carry a cycle total.
  totalKwh        Float?
  source          String    @default("green_button")
  createdAt       DateTime  @default(now())

  pump             Pump              @relation(fields: [pumpId], references: [id], onDelete: Cascade)
  billingLineItems BillingLineItem[] // the per-line-item breakdown that reconciles to printedTotalCents

  @@unique([pumpId, start]) // one summary per cycle; makes re-import idempotent
  @@index([pumpId, start])
}

// One line item composing a BillingPeriod's printed total (a TOU energy bucket, the
// demand charge, an NBC, or another printed line). Billed amounts are integer cents
// (AR-6, the reconciliation surface); quantity/rate keep full precision. Story 1.7 sums
// amountCents across a period's line items and reconciles to BillingPeriod.printedTotalCents.
model BillingLineItem {
  id              String   @id @default(cuid())
  billingPeriodId String
  kind            String // "tou_energy" | "demand" | "nbc" | "other"
  label           String?
  amountCents     Int // integer US cents, never a float
  quantity        Float? // kWh / kW, full precision
  unit            String? // "kWh" | "kW"
  rate            Float? // $/unit, full precision
  createdAt       DateTime @default(now())

  billingPeriod BillingPeriod @relation(fields: [billingPeriodId], references: [id], onDelete: Cascade)

  @@index([billingPeriodId])
}

model Crop {
  id              String @id @default(cuid())
  name            String @unique
  cropCoefficient Float? // Kc for CIMIS water math (later tool)

  blocks  Block[]
  ranches Ranch[]
  pumps   Pump[]
}

// The rollup level between Account and Meter (Entity -> Account -> Ranch -> Meter).
// Farm-scoped grouping that meters point to via Pump.ranchId; intentionally not nested
// strictly under Account (a ranch can hold meters from more than one account, and the
// billing link already lives on Pump.accountId). Distinct from the existing Block model,
// which the seed and the m-n served-block concept still use; Story 1.2 decides whether
// Block merges into Ranch once real ranch data lands.
model Ranch {
  id        String   @id @default(cuid())
  name      String
  acreage   Float?
  farmId    String
  cropId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farm  Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  crop  Crop?  @relation(fields: [cropId], references: [id])
  pumps Pump[] // meters grouped under this ranch

  @@index([farmId])
}

// A solar array (Batth runs two: 840 kW and 1,092 kW). Models the NEMA allocation as an
// explicit Array -> benefiting-Meter graph rather than flat meter flags: one array's
// credits offset many meters, and a meter can draw from more than one array. trueUpMonth
// is per array. Named SolarArray (never Array) to avoid shadowing the JS global Array<T>.
model SolarArray {
  id          String   @id @default(cuid())
  name        String?
  nameplateKw Float // array nameplate, e.g. 840 or 1092
  nemType     String? // "nem2" | "nem2_agg"
  trueUpMonth Int? // per-array annual true-up month (1-12)
  saId        String? // the generating meter's SA ID (the array's own service)
  farmId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  farm             Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  benefitingMeters Pump[] @relation("NemAllocation") // NEMA m-n: meters this array's credits offset

  @@index([farmId])
}

// One printed NEM reconciliation month for a generating meter (Story 3.4): the
// monthly net position exactly as PG&E's NEM statement prints it. The minimum
// NEM persistence - the full SolarArray/NEMA allocation graph stays deferred.
// netKwh negative = net export that month; amountCents negative = credit.
model NemPeriod {
  id          String   @id @default(cuid())
  pumpId      String
  start       DateTime
  close       DateTime
  netKwh      Float
  amountCents Int // integer cents, as printed (money law: never float dollars)
  source      String   @default("scanned_bill")
  createdAt   DateTime @default(now())

  pump Pump @relation(fields: [pumpId], references: [id], onDelete: Cascade)

  // One row per printed month per meter; the importer upserts on this.
  @@unique([pumpId, start])
  @@index([pumpId])
}

model Person {
  id        String   @id @default(cuid())
  name      String
  // Owner email captured at onboarding's "save it" step. Nullable: managers and
  // irrigators added later (and the owner row created before the save step) have none.
  email     String?
  role      String // "owner" | "manager" | "irrigator"
  language  String   @default("en") // "en" | "es"
  farmId    String
  createdAt DateTime @default(now())

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId])
}

model Connection {
  id           String    @id @default(cuid())
  type         String // "pge_smd" | "cimis" | "pesticide" | "payroll"
  status       String    @default("pending") // "pending" | "active" | "revoked"
  // How the data backing this connection actually arrived (provenance). Distinguishes a
  // true live Share-My-Data authorization from data that merely makes the farm the
  // dashboard farm (an uploaded bill or Green Button export), so the LOA-upgrade flow can
  // tell "already SMD-authorized" from "bill-only" instead of overloading type:"pge_smd".
  // Mirrored by the ConnectionSource union in src/lib/onboarding/sources.ts.
  source       String? // "smd" | "green_button" | "bill_upload" | "sample"
  externalRef  String? // provider-side id / authorization reference
  farmId       String
  createdAt    DateTime  @default(now())
  authorizedAt DateTime?

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId])
}

model Recommendation {
  id         String    @id @default(cuid())
  farmId     String
  tool       String // e.g. "pump-timing"
  situation  String
  action     Json // structured + displayable now, executable later
  impactUsd  Float?
  impactNote String?
  severity   String    @default("info") // "info" | "watch" | "act"
  status     String    @default("pending") // "pending" | "done" | "dismissed" | "overridden"
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  result     Json? // predicted vs actual after the loop closes

  farm         Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  agentActions AgentAction[]

  @@index([farmId, status])
  @@index([farmId, tool])
}

// A spreadsheet Almond generated for a grower and kept privately so it can be fetched again
// later (Story 8.6). Additive: it alters no existing model. Farm-scoped on `farmId` (the
// multi-tenant isolation gate, exactly like every other farm-owned row), with the owner-scoped
// download route re-checking ownership before streaming a byte. The bytes themselves live in
// PRIVATE Vercel Blob under a non-guessable cuid key recorded in `blobPathname`; this row records
// only WHAT the file was, WHEN it was made, and the request that produced it (never the bytes).
//
// `kind` is a String (SQLite/Postgres union convention used across this schema) mirrored by the
// `GeneratedReportKind` TS literal union in src/lib/almond/reports/store.ts.
//
// Immutability: a stored report is never rewritten in place. A refresh is a NEW row with new bytes
// under a new cuid key, so the history of what a grower was handed is preserved (no in-place edit).
model GeneratedReport {
  id String @id @default(cuid())

  // The farm this report belongs to (the isolation gate). The download route resolves the caller's
  // own farm and re-checks it matches before streaming, so one grower can never fetch another's file.
  farmId String

  // The signed-in grower who asked for it, when known. Nullable: a report can be produced in a
  // server context that has the farm but not a user row, and the owner check is on the FARM, not
  // this column. SetNull on user delete so a deleted account never cascades away the farm's reports.
  createdById String?

  // What the file is (the table shape). String + TS union (GeneratedReportKind), e.g. "meters".
  kind String

  // Human title for the report (the server-authored download file name's basis), e.g. "Acme meters".
  title String

  // The grower's request that produced it, captured verbatim for the Reports history.
  requestText String

  // The non-guessable cuid key the bytes live under in PRIVATE Vercel Blob (never a public URL).
  blobPathname String

  // The serialized file size in bytes (for the Reports list; the bytes themselves are in Blob).
  byteSize Int

  // The freshest billed cycle the figures reflect, as the export footer states it, or null when no
  // bill has posted (absence is explicit, never a fabricated date).
  coverageAsOf String?

  // The shape parameters the report was built from (table, filter), as JSON, so a refresh can
  // reproduce the SAME shape deterministically. Never carries a value or a farmId.
  paramsJson Json

  createdAt DateTime @default(now())

  farm      Farm  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  // Farm-scoped, newest-first reads (the Reports history list).
  @@index([farmId, createdAt])
  @@index([createdById])
}

// --- Agentic foundation (the shared agent ledger) -----------------------------
// Two append-only, farm-scoped models record WHAT an agent did, mirroring the
// GeneratedReport immutability pattern (a refresh is a NEW row, never an in-place
// rewrite). They are the audit trail and the human-in-the-loop approval gate for the
// four feature agents that arrive in their own worktrees (refresh, bill dispute, rate
// switch, solar watch, rebate). There is deliberately NO separate Approval model:
// approval is folded into AgentAction.status (proposed -> approved | rejected ->
// executed | failed) plus approvedById/approvedAt, so the whole human-in-the-loop is
// one row that survives every state.

// One run of one agent against one farm. A cron sweep or a manual trigger opens a run
// (status "running"), records zero or more AgentActions under it, and closes it
// ("succeeded" | "failed"). Farm-scoped on `farmId` (the multi-tenant isolation gate,
// exactly like every other farm-owned row). Append-only: a re-run is a NEW row, so the
// full history of what ran and when is preserved. `kind` is a String (the schema's
// SQLite/Postgres union convention) mirrored by the AgentRunKind TS literal union in
// src/lib/agents/types.ts.
model AgentRun {
  id String @id @default(cuid())

  // The farm this run belongs to (the isolation gate). Every read of a run is
  // farmId-scoped, and the audit UI resolves the caller's OWN farm before listing runs.
  farmId String

  // Which agent ran: "refresh" | "bill_dispute" | "rate_switch" | "solar_watch" |
  // "rebate" (AgentRunKind). String + TS union, never a DB enum (the schema convention).
  kind String

  // Lifecycle: "running" while in flight, then "succeeded" | "failed" (AgentRunStatus).
  status String @default("running")

  // How the run started, for the audit trail: "cron" (the system sweep, no user session)
  // or a user id / label when manually triggered. Free String, not a foreign key: a run
  // can be system-initiated with no owning user (the cron sweep runs with no session).
  triggeredBy String

  // An optional human-readable note set when the run completes (e.g. the failure reason
  // when PG&E MFA expired the authorization). Plain operator English where surfaced.
  note String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  farm    Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  actions AgentAction[]

  // Farm-scoped, newest-first reads (the audit list).
  @@index([farmId, createdAt])
  // The cadence-window skip query: most-recent completed run of a kind for a farm.
  @@index([farmId, kind, status])
}

// One thing an agent proposed (and possibly executed) during a run. This is BOTH the
// audit row and the approval gate: a v1 agent never touches an external API on its own,
// it RECORDS a proposed action (status "proposed") that the farm OWNER must approve in
// the audit UI; approval transitions it to "approved" then the same call executes it to
// "executed" (or "failed"), recording-and-handing-off only (it still makes no external
// call in v1). A rejected proposal is "rejected" and terminal. Append-only and immutable
// in spirit: the status walks forward through the state machine, the payload is never
// rewritten. Farm-scoped on `farmId` (denormalized off the run so every query, including
// the cross-farm ownership gate, is farmId-scoped without a join).
model AgentAction {
  id String @id @default(cuid())

  // The run that produced this action. Cascade: deleting a run removes its actions.
  agentRunId String

  // The farm this action belongs to (the isolation gate, denormalized off the run so the
  // ownership chokepoint can scope on it directly). Cascade with the farm.
  farmId String

  // The Recommendation this action acts on, when it derives from one (e.g. a bill-dispute
  // action for a specific finding). Nullable + SetNull: deleting the Recommendation must
  // NOT cascade away the audit row (what the agent did is preserved even if the finding is
  // later cleared), it only nulls the link.
  recommendationId String?

  // What the action does in the agent's vocabulary (e.g. "draft_dispute_email",
  // "switch_rate"). String, feature-defined, never a DB enum.
  kind String

  // One-line human summary of the action, in plain operator English (shown in the audit
  // UI). No em dashes.
  summary String

  // The approval state machine: "proposed" -> "approved" | "rejected" -> "executed" |
  // "failed" (AgentActionStatus). Defaults to "proposed": every action waits for the
  // owner. The transition is an atomic updateMany guarded on this column so a double-tap
  // cannot double-fire.
  status String @default("proposed")

  // The structured command an approver would execute, captured so a human can review
  // EXACTLY what would happen before approving (e.g. the rate-switch request). JSON,
  // nullable. Never carries a secret or another farm's id.
  proposedCommand Json?

  // An optional drafted email (subject + body) the action would send on execution, kept
  // verbatim so the owner reviews the literal words before approving. Plain text, not HTML.
  draftSubject String?
  draftBody    String?

  // An optional GeneratedReport id the action produced or references (a loose link, not a
  // foreign key: the report has its own farm-scoped lifecycle and download route).
  reportId String?

  // The human-in-the-loop stamps: who approved and when. Both null until approval. A loose
  // user id String (not an FK) so a deleted account never cascades away the audit row.
  approvedById String?
  approvedAt   DateTime?

  createdAt DateTime @default(now())

  agentRun       AgentRun        @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  farm           Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  recommendation Recommendation? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)

  // Actions under one run, in order.
  @@index([agentRunId])
  // Reverse lookup from a finding to the actions that touched it.
  @@index([recommendationId])
  // The pending-approval query: this farm's proposed actions awaiting the owner.
  @@index([farmId, status])
}

// --- Auth.js v5 (@auth/prisma-adapter) ----------------------------------------
// The four tables the Prisma adapter needs for sign-in (Story 5.1). One twist: the
// adapter calls a delegate named `account` for OAuth links, but Terra ALREADY has a
// `model Account` (the PG&E billing account, above), which we must not disturb. So the
// OAuth-link model is named `AuthAccount` here and lib/auth.ts wraps the adapter to map
// its `account` delegate onto `authAccount`. Session is JWT-strategy (see lib/auth.ts),
// so the Session table is created but not populated; it stays for adapter-schema
// completeness and a possible future switch to database sessions.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         AuthAccount[]
  sessions         Session[]
  farms            Farm[]
  generatedReports GeneratedReport[]
}

// OAuth account link (renamed from the adapter's default `Account` to avoid colliding
// with the PG&E billing Account). lib/auth.ts maps the adapter's `account` -> `authAccount`.
model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
