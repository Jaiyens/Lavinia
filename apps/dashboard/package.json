    "db:import-fixture": "tsx scripts/persist-demo-fixture.ts",
    "levers:run": "tsx scripts/run-levers.ts",
    "extract:bills": "tsx scripts/extract-bills-batch.ts",
    "verify:reconciliation": "tsx scripts/verify-reconciliation.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
