{
  "name": "@lavinia/dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "next build && playwright test",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:check": "bash scripts/check-migrate-deploy.sh",
    "db:reset": "prisma db push --force-reset --skip-generate && prisma db seed",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:load:batth": "bash scripts/db-load-batth.sh",
    "db:dump:batth": "bash scripts/db-dump-batth.sh",
    "db:restore:batth": "bash scripts/db-restore-batth.sh",
    "preview:seeded": "next build && node scripts/preview-seeded.mjs",
