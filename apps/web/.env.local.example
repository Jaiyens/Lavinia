# Terra — environment variables
# Copy this file to `.env.local` and fill in real values.

# --- Multi-Zone: the farmer dashboard (REQUIRED in production) ------------------
# This marketing site rewrites /dashboard/* to the dashboard app (Next.js Multi-Zones,
# see next.config.ts). DASHBOARD_URL is the dashboard's origin WITHOUT a trailing path
# (the rewrite appends /dashboard itself). If unset it falls back to http://localhost:3001
# for local dev, which BREAKS /dashboard in production. On Vercel set this on the web
# project to the dashboard project's URL, e.g. https://lavinia-dashboard.vercel.app (or,
# better, a stable custom domain like https://dashboard.tryterra.ai).
DASHBOARD_URL=http://localhost:3001

# --- Inquire form (Resend) -----------------------------------------------------
# The inquire form works WITHOUT these (submissions are logged to the server
# console), but to actually receive emails, set all three.

# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=

# Where inquiries are delivered. Comma-separate for multiple recipients.
INQUIRY_TO_EMAIL=team@terra.farm

# Verified "from" address. Until you verify a domain in Resend you can use
# the shared sandbox sender below (works only to your own Resend account email).
INQUIRY_FROM_EMAIL=Terra <onboarding@resend.dev>
