# dependencies
node_modules/

# build output
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# turbo
.turbo/

# vercel
.vercel/

# env files (never commit secrets)
.env
.env.*
!.env.example
!.env.*.example

# prisma local db
*.db
*.db-journal

# os / editor
.DS_Store
Thumbs.db

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vercel

# BMad Method (local-only personal tooling, not part of the product)
_bmad/
_bmad-output/
.claude/skills/
# BMad skill packs land under any workspace's .claude/skills (e.g. apps/dashboard); the
# root-anchored rule above misses those, so match the bmad-* skill dirs at any depth.
**/.claude/skills/bmad-*/

# Personal Claude Code overrides for this project (not shared)
.claude/settings.local.json

# overnight orchestration scaffolding (not product code)
.night/

# Batth data-ingestion run (autonomous): outputs + quarantined raw dupes (large/derived, not product code).
# Ignore everything under batth-ingestion/ (incl. reports/ = run logs only)...
batth-ingestion/*
# ...but TRACK the two small loadable artifacts collaborators need to load the farm locally
# (the loader reads bills + interval_aggregates.json). Re-include the dirs so git descends into them.
!batth-ingestion/extracted/
!batth-ingestion/dist/
BatthData/_dupes/
